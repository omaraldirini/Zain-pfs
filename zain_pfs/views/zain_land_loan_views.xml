<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form view ─────────────────────────────────────────────────────── -->
    <record id="view_zain_land_loan_form" model="ir.ui.view">
        <field name="name">zain.land.loan.form</field>
        <field name="model">zain.land.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit to HR" type="object"
                            invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_to_preparation" string="Move to Preparation" type="object"
                            invisible="state != 'submitted'"
                            groups="zain_pfs.group_pfs_hr"/>
                    <button name="action_approval_1" string="Send for Approval #1" type="object"
                            invisible="state != 'preparation'"
                            groups="zain_pfs.group_pfs_fund_admin"/>
                    <button name="action_approval_2" string="Send for Approval #2" type="object"
                            invisible="state != 'approval_1'"
                            groups="zain_pfs.group_pfs_fund_committee"/>
                    <button name="action_pending_payment" string="Final Approval" type="object"
                            invisible="state != 'approval_2'"
                            groups="zain_pfs.group_pfs_fund_committee"
                            class="btn-primary"/>
                    <button name="action_disburse" string="Disburse &amp; Reserve Plot" type="object"
                            invisible="state != 'pending_payment'"
                            groups="zain_pfs.group_pfs_fund_admin"
                            class="btn-primary"/>
                    <button name="action_mark_paid" string="Mark as Paid" type="object"
                            invisible="state != 'active'"
                            groups="zain_pfs.group_pfs_fund_admin"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('active', 'paid', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('cancelled', 'submitted')"
                            groups="zain_pfs.group_pfs_fund_admin"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,preparation,approval_1,approval_2,pending_payment,active,paid"/>
                </header>

                <sheet>
                    <!-- Stat buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_mark_paid"
                                icon="fa-exclamation-triangle"
                                invisible="overdue_count == 0">
                            <field name="overdue_count" widget="statinfo" string="Overdue"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- ── Application ──────────────────────────────────────── -->
                    <group>
                        <group string="Application">
                            <field name="member_id"
                                   readonly="state != 'draft'"/>
                            <field name="date"/>
                        </group>
                        <group string="Member Summary" invisible="not member_id">
                            <field name="member_contribution_months" readonly="1"/>
                            <field name="member_balance" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Land plot ─────────────────────────────────────────── -->
                    <group string="Land Plot">
                        <group>
                            <field name="land_id"
                                   readonly="state != 'draft'"/>
                            <field name="land_price" readonly="1"/>
                        </group>
                        <group invisible="not land_id">
                            <field name="land_area" readonly="1"/>
                            <field name="land_location" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Financing ─────────────────────────────────────────── -->
                    <group string="Financing">
                        <group>
                            <field name="down_payment"
                                   readonly="state not in ('draft', 'submitted')"/>
                            <field name="installments"
                                   readonly="state not in ('draft', 'submitted')"/>
                        </group>
                        <group>
                            <field name="financed_amount" readonly="1"/>
                            <field name="installment_amount" readonly="1"/>
                            <field name="first_installment" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Balances ──────────────────────────────────────────── -->
                    <group string="Balances"
                           invisible="state not in ('active', 'paid')">
                        <field name="paid_amount" readonly="1"/>
                        <field name="remaining_balance" readonly="1"/>
                    </group>

                    <!-- ── Payment details ───────────────────────────────────── -->
                    <group string="Payment Details"
                           invisible="state not in ('pending_payment', 'active', 'paid')">
                        <group>
                            <field name="payment_method"/>
                            <field name="disbursement_date" readonly="1"
                                   invisible="not disbursement_date"/>
                        </group>
                        <group invisible="payment_method != 'cheque'">
                            <field name="cheque_number"/>
                            <field name="cheque_date"/>
                            <field name="cheque_amount"/>
                        </group>
                    </group>

                    <field name="notes" placeholder="Notes..."/>

                    <!-- ── Repayment schedule ────────────────────────────────── -->
                    <notebook>
                        <page string="Repayment Schedule" name="schedule"
                              invisible="state not in ('active', 'paid')">
                            <field name="line_ids">
                                <list editable="bottom"
                                      decoration-danger="not paid and date and date &lt; context_today()"
                                      decoration-success="paid">
                                    <field name="sequence" optional="hide"/>
                                    <field name="date" string="Due Date"/>
                                    <field name="amount" string="Amount (JOD)"/>
                                    <field name="paid"/>
                                    <field name="payment_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List view ─────────────────────────────────────────────────────── -->
    <record id="view_zain_land_loan_list" model="ir.ui.view">
        <field name="name">zain.land.loan.list</field>
        <field name="model">zain.land.loan</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-warning="overdue_count &gt; 0"
                  decoration-success="state == 'active' and overdue_count == 0"
                  decoration-muted="state in ('paid', 'cancelled')">
                <field name="name"/>
                <field name="member_id"/>
                <field name="land_id"/>
                <field name="land_price"/>
                <field name="down_payment"/>
                <field name="installments"/>
                <field name="financed_amount"/>
                <field name="remaining_balance"/>
                <field name="overdue_count" string="Overdue" optional="show"/>
                <field name="disbursement_date" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- ── Search view ───────────────────────────────────────────────────── -->
    <record id="view_zain_land_loan_search" model="ir.ui.view">
        <field name="name">zain.land.loan.search</field>
        <field name="model">zain.land.loan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="member_id"/>
                <field name="land_id"/>
                <filter name="active_loans" string="Active"
                        domain="[('state','=','active')]"/>
                <filter name="pending" string="Pending Approval"
                        domain="[('state','in',['submitted','preparation','approval_1','approval_2'])]"/>
                <filter name="pending_payment" string="Pending Payment"
                        domain="[('state','=','pending_payment')]"/>
                <separator/>
                <filter name="paid" string="Paid"
                        domain="[('state','=','paid')]"/>
                <group>
                    <filter name="group_member" string="Member"
                            context="{'group_by': 'member_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="action_zain_land_loan" model="ir.actions.act_window">
        <field name="name">Land Loans</field>
        <field name="res_model">zain.land.loan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_zain_land_loan_search"/>
        <field name="context">{'search_default_active_loans': 1}</field>
    </record>

</odoo>
