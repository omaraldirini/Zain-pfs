<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form view ─────────────────────────────────────────────────────── -->
    <record id="view_zain_withdrawal_form" model="ir.ui.view">
        <field name="name">zain.withdrawal.form</field>
        <field name="model">zain.withdrawal</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit to HR" type="object"
                            invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_to_approval_1" string="HR Approved – Send to Committee" type="object"
                            invisible="state != 'hr_review'"
                            groups="zain_pfs.group_pfs_hr"/>
                    <button name="action_to_approval_2" string="Approval #1 Done" type="object"
                            invisible="state != 'approval_1'"
                            groups="zain_pfs.group_pfs_fund_committee"/>
                    <button name="action_approve" string="Final Approval" type="object"
                            invisible="state != 'approval_2'"
                            groups="zain_pfs.group_pfs_fund_committee"
                            class="btn-primary"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('approved', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"
                            groups="zain_pfs.group_pfs_fund_admin"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,hr_review,approval_1,approval_2,approved"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- ── Request ──────────────────────────────────────────── -->
                    <group>
                        <group string="Request">
                            <field name="member_id"
                                   readonly="state != 'draft'"/>
                            <field name="date"/>
                            <field name="withdrawal_type"
                                   readonly="state not in ('draft',)"/>
                            <field name="requested_amount"
                                   readonly="state not in ('draft',)"/>
                        </group>
                        <group string="Member Summary" invisible="not member_id">
                            <field name="member_contribution_months" readonly="1"/>
                            <field name="member_balance" readonly="1"/>
                            <field name="eligible_amount" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Amounts breakdown ─────────────────────────────────── -->
                    <group string="Amounts" invisible="state == 'draft'">
                        <group>
                            <field name="net_amount" readonly="1" string="Effective Amount (JOD)"/>
                            <field name="is_loan_settlement" readonly="1"/>
                            <field name="loan_settlement_amount" readonly="1"
                                   invisible="not is_loan_settlement"/>
                            <field name="cash_amount" readonly="1"
                                   invisible="not is_loan_settlement"/>
                        </group>
                        <group invisible="withdrawal_type != '50'">
                            <field name="lock_years" readonly="1"/>
                            <field name="lock_expiry_date" readonly="1"
                                   invisible="not lock_expiry_date"/>
                        </group>
                    </group>

                    <!-- ── Disbursement (cash portion) ───────────────────────── -->
                    <group string="Disbursement Details"
                           invisible="state not in ('approval_2', 'approved')">
                        <field name="payment_method"
                               readonly="state == 'approved'"/>
                        <field name="cheque_number"
                               invisible="payment_method != 'cheque'"
                               readonly="state == 'approved'"/>
                        <field name="cheque_date"
                               invisible="payment_method != 'cheque'"
                               readonly="state == 'approved'"/>
                        <field name="cheque_amount"
                               invisible="payment_method != 'cheque'"
                               readonly="state == 'approved'"/>
                    </group>

                    <!-- ── Approval result ───────────────────────────────────── -->
                    <group string="Approval" invisible="state != 'approved'">
                        <field name="approved_amount" readonly="1"/>
                        <field name="approved_date" readonly="1"/>
                        <field name="member_balance_at_approval" readonly="1"/>
                    </group>

                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List view ─────────────────────────────────────────────────────── -->
    <record id="view_zain_withdrawal_list" model="ir.ui.view">
        <field name="name">zain.withdrawal.list</field>
        <field name="model">zain.withdrawal</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'approved'"
                  decoration-muted="state == 'cancelled'"
                  decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="member_id"/>
                <field name="date"/>
                <field name="withdrawal_type"/>
                <field name="requested_amount"/>
                <field name="eligible_amount"/>
                <field name="is_loan_settlement" optional="show"/>
                <field name="loan_settlement_amount" optional="hide"/>
                <field name="cash_amount" optional="hide"/>
                <field name="approved_amount"/>
                <field name="approved_date" optional="hide"/>
                <field name="lock_expiry_date" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- ── Search view ───────────────────────────────────────────────────── -->
    <record id="view_zain_withdrawal_search" model="ir.ui.view">
        <field name="name">zain.withdrawal.search</field>
        <field name="model">zain.withdrawal</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="member_id"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="pending" string="Pending"
                        domain="[('state','in',['hr_review','approval_1','approval_2'])]"/>
                <filter name="approved" string="Approved"
                        domain="[('state','=','approved')]"/>
                <filter name="type_50" string="50% Withdrawal"
                        domain="[('withdrawal_type','=','50')]"/>
                <filter name="type_75" string="75% Withdrawal"
                        domain="[('withdrawal_type','=','75')]"/>
                <filter name="loan_settlement" string="With Loan Settlement"
                        domain="[('is_loan_settlement','=',True)]"/>
                <separator/>
                <filter name="locked" string="Still Locked"
                        domain="[('lock_expiry_date','&gt;',context_today())]"/>
                <group>
                    <filter name="group_member" string="Member"
                            context="{'group_by': 'member_id'}"/>
                    <filter name="group_type" string="Withdrawal Type"
                            context="{'group_by': 'withdrawal_type'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="action_zain_withdrawal" model="ir.actions.act_window">
        <field name="name">Withdrawals</field>
        <field name="res_model">zain.withdrawal</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_zain_withdrawal_search"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

</odoo>
